# Ensure consistent LF line endings for all text files (Ansible/KYPO runs on Linux)
* text=auto eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.j2 text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.php text eol=lf
*.py text eol=lf
*.eml text eol=lf
*.log text eol=lf
*.css text eol=lf
*.html text eol=lf
